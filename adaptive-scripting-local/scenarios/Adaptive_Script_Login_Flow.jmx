<?xml version="1.0" encoding="UTF-8"?>
<jmeterTestPlan version="1.2" properties="5.0" jmeter="5.5">
  <hashTree>
    <TestPlan guiclass="TestPlanGui" testclass="TestPlan"
              testname="Adaptive Scripting - OIDC Auth Code Login Flow" enabled="true">
      <stringProp name="TestPlan.comments">
        Tests the OIDC Authorization Code flow against a locally running WSO2 IS.
        This is the flow that adaptive scripts intercept and can augment.

        Flow (IS 7.2.x):
          1.  GET  /oauth2/authorize        → IS redirects to login; extract sessionDataKey
          2.  POST /commonauth              → Submit credentials; IS redirects to internal re-auth step
          2b. GET  /t/carbon.super/oauth2/authorize  → IS issues auth code; extract code from redirect
          3.  POST /oauth2/token            → Exchange code for tokens; assert access_token + id_token

        To test different adaptive scripts:
          - Configure the adaptive script on the IS application via Management Console
          - If the script adds extra steps (TOTP, IP check, etc.), duplicate this JMX and
            add the extra HTTP requests after step 2 before step 3.

        Parameters (set in config.properties or passed with -J on the command line):
          host, port, clientId, clientSecret, callbackUrl,
          testUsername, testPassword, concurrency, duration, rampup
      </stringProp>
      <boolProp name="TestPlan.functional_mode">false</boolProp>
      <boolProp name="TestPlan.serialize_threadgroups">false</boolProp>
      <elementProp name="TestPlan.user_defined_variables" elementType="Arguments"
                   guiclass="ArgumentsPanel" testclass="Arguments" enabled="true">
        <collectionProp name="Arguments.arguments"/>
      </elementProp>
      <stringProp name="TestPlan.user_define_classpath"></stringProp>
    </TestPlan>
    <hashTree>

      <!-- =========================================================
           Server Variables
           ========================================================= -->
      <Arguments guiclass="ArgumentsPanel" testclass="Arguments"
                 testname="Server Variables" enabled="true">
        <collectionProp name="Arguments.arguments">
          <elementProp name="is_host" elementType="Argument">
            <stringProp name="Argument.name">is_host</stringProp>
            <stringProp name="Argument.value">${__P(host,localhost)}</stringProp>
            <stringProp name="Argument.metadata">=</stringProp>
          </elementProp>
          <elementProp name="is_port" elementType="Argument">
            <stringProp name="Argument.name">is_port</stringProp>
            <stringProp name="Argument.value">${__P(port,9443)}</stringProp>
            <stringProp name="Argument.metadata">=</stringProp>
          </elementProp>
        </collectionProp>
      </Arguments>
      <hashTree/>

      <!-- =========================================================
           OAuth App Variables
           ========================================================= -->
      <Arguments guiclass="ArgumentsPanel" testclass="Arguments"
                 testname="OAuth App Variables" enabled="true">
        <collectionProp name="Arguments.arguments">
          <elementProp name="clientId" elementType="Argument">
            <stringProp name="Argument.name">clientId</stringProp>
            <stringProp name="Argument.value">${__P(clientId,YOUR_CLIENT_ID_HERE)}</stringProp>
            <stringProp name="Argument.metadata">=</stringProp>
          </elementProp>
          <elementProp name="clientSecret" elementType="Argument">
            <stringProp name="Argument.name">clientSecret</stringProp>
            <stringProp name="Argument.value">${__P(clientSecret,YOUR_CLIENT_SECRET_HERE)}</stringProp>
            <stringProp name="Argument.metadata">=</stringProp>
          </elementProp>
          <elementProp name="callbackUrl" elementType="Argument">
            <stringProp name="Argument.name">callbackUrl</stringProp>
            <stringProp name="Argument.value">${__P(callbackUrl,https://localhost/callback)}</stringProp>
            <stringProp name="Argument.metadata">=</stringProp>
          </elementProp>
        </collectionProp>
      </Arguments>
      <hashTree/>

      <!-- =========================================================
           Test / Thread Variables
           ========================================================= -->
      <Arguments guiclass="ArgumentsPanel" testclass="Arguments"
                 testname="Test Variables" enabled="true">
        <collectionProp name="Arguments.arguments">
          <elementProp name="testUsername" elementType="Argument">
            <stringProp name="Argument.name">testUsername</stringProp>
            <stringProp name="Argument.value">${__P(testUsername,adaptive_test_user)}</stringProp>
            <stringProp name="Argument.metadata">=</stringProp>
          </elementProp>
          <elementProp name="testPassword" elementType="Argument">
            <stringProp name="Argument.name">testPassword</stringProp>
            <stringProp name="Argument.value">${__P(testPassword,Test@1234!)}</stringProp>
            <stringProp name="Argument.metadata">=</stringProp>
          </elementProp>
          <elementProp name="noOfThreads" elementType="Argument">
            <stringProp name="Argument.name">noOfThreads</stringProp>
            <stringProp name="Argument.value">${__P(concurrency,5)}</stringProp>
            <stringProp name="Argument.metadata">=</stringProp>
          </elementProp>
          <elementProp name="timeToRun" elementType="Argument">
            <stringProp name="Argument.name">timeToRun</stringProp>
            <stringProp name="Argument.value">${__P(duration,120)}</stringProp>
            <stringProp name="Argument.metadata">=</stringProp>
          </elementProp>
          <elementProp name="rampUpPeriod" elementType="Argument">
            <stringProp name="Argument.name">rampUpPeriod</stringProp>
            <stringProp name="Argument.value">${__P(rampup,20)}</stringProp>
            <stringProp name="Argument.metadata">=</stringProp>
          </elementProp>
        </collectionProp>
      </Arguments>
      <hashTree/>

      <!-- =========================================================
           HTTP Cookie Manager
           IS login flow relies on cookies (JSESSIONID, commonAuthId, etc.)
           ========================================================= -->
      <CookieManager guiclass="CookiePanel" testclass="CookieManager"
                     testname="HTTP Cookie Manager" enabled="true">
        <collectionProp name="CookieManager.cookies"/>
        <boolProp name="CookieManager.clearEachIteration">true</boolProp>
        <boolProp name="CookieManager.controlledByThreadGroup">false</boolProp>
      </CookieManager>
      <hashTree/>

      <!-- =========================================================
           Main Thread Group
           ========================================================= -->
      <ThreadGroup guiclass="ThreadGroupGui" testclass="ThreadGroup"
                   testname="Adaptive Script Login Flow" enabled="true">
        <stringProp name="ThreadGroup.on_sample_error">continue</stringProp>
        <elementProp name="ThreadGroup.main_controller" elementType="LoopController"
                     guiclass="LoopControlPanel" testclass="LoopController" enabled="true">
          <boolProp name="LoopController.continue_forever">false</boolProp>
          <intProp name="LoopController.loops">-1</intProp>
        </elementProp>
        <stringProp name="ThreadGroup.num_threads">${noOfThreads}</stringProp>
        <stringProp name="ThreadGroup.ramp_time">${rampUpPeriod}</stringProp>
        <boolProp name="ThreadGroup.scheduler">true</boolProp>
        <stringProp name="ThreadGroup.duration">${timeToRun}</stringProp>
        <stringProp name="ThreadGroup.delay">0</stringProp>
        <boolProp name="ThreadGroup.delayedStart">false</boolProp>
        <boolProp name="ThreadGroup.same_user_on_next_iteration">false</boolProp>
      </ThreadGroup>
      <hashTree>

        <!-- STEP 1: GET /oauth2/authorize
             IS redirects to login page; extract sessionDataKey from the redirect URL. -->
        <HTTPSamplerProxy guiclass="HttpTestSampleGui" testclass="HTTPSamplerProxy"
                          testname="1 GET /oauth2/authorize" enabled="true">
          <elementProp name="HTTPsampler.Arguments" elementType="Arguments"
                       guiclass="HTTPArgumentsPanel" testclass="Arguments" enabled="true">
            <collectionProp name="Arguments.arguments">
              <elementProp name="client_id" elementType="HTTPArgument">
                <boolProp name="HTTPArgument.always_encode">false</boolProp>
                <stringProp name="Argument.value">${clientId}</stringProp>
                <stringProp name="Argument.metadata">=</stringProp>
                <boolProp name="HTTPArgument.use_equals">true</boolProp>
                <stringProp name="Argument.name">client_id</stringProp>
              </elementProp>
              <elementProp name="redirect_uri" elementType="HTTPArgument">
                <boolProp name="HTTPArgument.always_encode">true</boolProp>
                <stringProp name="Argument.value">${callbackUrl}</stringProp>
                <stringProp name="Argument.metadata">=</stringProp>
                <boolProp name="HTTPArgument.use_equals">true</boolProp>
                <stringProp name="Argument.name">redirect_uri</stringProp>
              </elementProp>
              <elementProp name="response_type" elementType="HTTPArgument">
                <boolProp name="HTTPArgument.always_encode">false</boolProp>
                <stringProp name="Argument.value">code</stringProp>
                <stringProp name="Argument.metadata">=</stringProp>
                <boolProp name="HTTPArgument.use_equals">true</boolProp>
                <stringProp name="Argument.name">response_type</stringProp>
              </elementProp>
              <elementProp name="scope" elementType="HTTPArgument">
                <boolProp name="HTTPArgument.always_encode">false</boolProp>
                <stringProp name="Argument.value">openid</stringProp>
                <stringProp name="Argument.metadata">=</stringProp>
                <boolProp name="HTTPArgument.use_equals">true</boolProp>
                <stringProp name="Argument.name">scope</stringProp>
              </elementProp>
            </collectionProp>
          </elementProp>
          <stringProp name="HTTPSampler.domain">${is_host}</stringProp>
          <stringProp name="HTTPSampler.port">${is_port}</stringProp>
          <stringProp name="HTTPSampler.protocol">https</stringProp>
          <stringProp name="HTTPSampler.path">/oauth2/authorize</stringProp>
          <stringProp name="HTTPSampler.method">GET</stringProp>
          <!-- Do NOT follow redirect: we want to read the Location header for sessionDataKey -->
          <boolProp name="HTTPSampler.follow_redirects">false</boolProp>
          <boolProp name="HTTPSampler.auto_redirects">false</boolProp>
          <boolProp name="HTTPSampler.use_keepalive">true</boolProp>
          <boolProp name="HTTPSampler.DO_MULTIPART_POST">false</boolProp>
          <stringProp name="HTTPSampler.implementation">HttpClient4</stringProp>
          <stringProp name="HTTPSampler.connect_timeout">10000</stringProp>
          <stringProp name="HTTPSampler.response_timeout">30000</stringProp>
          <stringProp name="TestPlan.comments">
            Expects HTTP 302 redirect to the IS login page.
            Location header will contain: sessionDataKey=XXXXXXXX
          </stringProp>
        </HTTPSamplerProxy>
        <hashTree>
          <!-- Assert we got a redirect (302) -->
          <ResponseAssertion guiclass="AssertionGui" testclass="ResponseAssertion"
                             testname="Assert 302 Redirect to Login" enabled="true">
            <collectionProp name="Asserion.test_strings">
              <stringProp name="103171778">HTTP/1.1 302</stringProp>
            </collectionProp>
            <stringProp name="Assertion.test_field">Assertion.response_headers</stringProp>
            <boolProp name="Assertion.assume_success">false</boolProp>
            <intProp name="Assertion.test_type">2</intProp>
            <stringProp name="Assertion.custom_message">
              Step 1 failed: Expected 302 redirect from /oauth2/authorize.
              Check that clientId is correct and IS is running.
            </stringProp>
          </ResponseAssertion>
          <hashTree/>

          <!-- Extract sessionDataKey from the Location header -->
          <RegexExtractor guiclass="RegexExtractorGui" testclass="RegexExtractor"
                          testname="Extract sessionDataKey" enabled="true">
            <stringProp name="RegexExtractor.useHeaders">true</stringProp>
            <stringProp name="RegexExtractor.refname">sessionDataKey</stringProp>
            <stringProp name="RegexExtractor.regex">sessionDataKey=([^&amp;\s"]+)</stringProp>
            <stringProp name="RegexExtractor.template">$1$</stringProp>
            <stringProp name="RegexExtractor.default">SESSION_DATA_KEY_NOT_FOUND</stringProp>
            <stringProp name="RegexExtractor.match_number">1</stringProp>
          </RegexExtractor>
          <hashTree/>

          <!-- Fail early if sessionDataKey was not found -->
          <JSR223Assertion guiclass="TestBeanGUI" testclass="JSR223Assertion"
                           testname="Assert sessionDataKey Extracted" enabled="true">
            <stringProp name="cacheKey">true</stringProp>
            <stringProp name="filename"></stringProp>
            <stringProp name="parameters"></stringProp>
            <stringProp name="scriptLanguage">groovy</stringProp>
            <stringProp name="script">
def key = vars.get("sessionDataKey")
if (key == null || key == "SESSION_DATA_KEY_NOT_FOUND") {
    AssertionResult.setFailure(true)
    AssertionResult.setFailureMessage(
        "sessionDataKey not found in Location header redirect.\n" +
        "Check that clientId is registered in IS and the app has Authorization Code grant."
    )
}
            </stringProp>
          </JSR223Assertion>
          <hashTree/>
        </hashTree>

        <!-- STEP 2: POST /commonauth - Submit credentials.
             The adaptive script (GraalJS) runs inside IS here.
             IS 7.2.x redirects to /t/carbon.super/oauth2/authorize?sessionDataKey=NEW_KEY
             (an internal IS re-authorization step - NOT directly to the callback).
             Step 2b below follows that redirect to get the auth code. -->
        <HTTPSamplerProxy guiclass="HttpTestSampleGui" testclass="HTTPSamplerProxy"
                          testname="2 POST /commonauth (Submit Credentials)" enabled="true">
          <elementProp name="HTTPsampler.Arguments" elementType="Arguments"
                       guiclass="HTTPArgumentsPanel" testclass="Arguments" enabled="true">
            <collectionProp name="Arguments.arguments">
              <elementProp name="sessionDataKey" elementType="HTTPArgument">
                <boolProp name="HTTPArgument.always_encode">true</boolProp>
                <stringProp name="Argument.value">${sessionDataKey}</stringProp>
                <stringProp name="Argument.metadata">=</stringProp>
                <boolProp name="HTTPArgument.use_equals">true</boolProp>
                <stringProp name="Argument.name">sessionDataKey</stringProp>
              </elementProp>
              <elementProp name="username" elementType="HTTPArgument">
                <boolProp name="HTTPArgument.always_encode">true</boolProp>
                <stringProp name="Argument.value">${testUsername}</stringProp>
                <stringProp name="Argument.metadata">=</stringProp>
                <boolProp name="HTTPArgument.use_equals">true</boolProp>
                <stringProp name="Argument.name">username</stringProp>
              </elementProp>
              <elementProp name="password" elementType="HTTPArgument">
                <boolProp name="HTTPArgument.always_encode">true</boolProp>
                <stringProp name="Argument.value">${testPassword}</stringProp>
                <stringProp name="Argument.metadata">=</stringProp>
                <boolProp name="HTTPArgument.use_equals">true</boolProp>
                <stringProp name="Argument.name">password</stringProp>
              </elementProp>
            </collectionProp>
          </elementProp>
          <stringProp name="HTTPSampler.domain">${is_host}</stringProp>
          <stringProp name="HTTPSampler.port">${is_port}</stringProp>
          <stringProp name="HTTPSampler.protocol">https</stringProp>
          <stringProp name="HTTPSampler.path">/commonauth</stringProp>
          <stringProp name="HTTPSampler.method">POST</stringProp>
          <!-- Do NOT follow redirect: we want the auth code from Location header -->
          <boolProp name="HTTPSampler.follow_redirects">false</boolProp>
          <boolProp name="HTTPSampler.auto_redirects">false</boolProp>
          <boolProp name="HTTPSampler.use_keepalive">true</boolProp>
          <boolProp name="HTTPSampler.DO_MULTIPART_POST">false</boolProp>
          <stringProp name="HTTPSampler.implementation">HttpClient4</stringProp>
          <stringProp name="HTTPSampler.connect_timeout">10000</stringProp>
          <stringProp name="HTTPSampler.response_timeout">30000</stringProp>
          <stringProp name="TestPlan.comments">
            THIS IS WHERE THE ADAPTIVE SCRIPT RUNS on the IS side (GraalJS).
            IS 7.2.x redirects to /t/carbon.super/oauth2/authorize?sessionDataKey=NEW_KEY
            (NOT directly to the callback). Step 2b follows that internal redirect.
          </stringProp>
        </HTTPSamplerProxy>
        <hashTree>
          <!-- Assert 302 redirect to post-auth step -->
          <ResponseAssertion guiclass="AssertionGui" testclass="ResponseAssertion"
                             testname="Assert 302 Redirect from commonauth" enabled="true">
            <collectionProp name="Asserion.test_strings">
              <stringProp name="103171778">HTTP/1.1 302</stringProp>
            </collectionProp>
            <stringProp name="Assertion.test_field">Assertion.response_headers</stringProp>
            <boolProp name="Assertion.assume_success">false</boolProp>
            <intProp name="Assertion.test_type">2</intProp>
            <stringProp name="Assertion.custom_message">
              Step 2 failed: Expected 302 redirect from /commonauth.
              Possible causes: wrong credentials, adaptive script denied access.
            </stringProp>
          </ResponseAssertion>
          <hashTree/>

          <!-- Extract the post-auth sessionDataKey from the /commonauth redirect.
               IS 7.2.x redirects to /t/carbon.super/oauth2/authorize?sessionDataKey=NEW_KEY
               instead of directly to the callback. We must follow this one more hop. -->
          <RegexExtractor guiclass="RegexExtractorGui" testclass="RegexExtractor"
                          testname="Extract Post-Auth SessionDataKey" enabled="true">
            <stringProp name="RegexExtractor.useHeaders">true</stringProp>
            <stringProp name="RegexExtractor.refname">postAuthSessionKey</stringProp>
            <stringProp name="RegexExtractor.regex">sessionDataKey=([^&amp;\s"]+)</stringProp>
            <stringProp name="RegexExtractor.template">$1$</stringProp>
            <stringProp name="RegexExtractor.default">POST_AUTH_KEY_NOT_FOUND</stringProp>
            <stringProp name="RegexExtractor.match_number">1</stringProp>
          </RegexExtractor>
          <hashTree/>

          <!-- Fail if authentication was rejected (redirect back to login with authFailure) -->
          <JSR223Assertion guiclass="TestBeanGUI" testclass="JSR223Assertion"
                           testname="Assert Auth Accepted (not authFailure)" enabled="true">
            <stringProp name="cacheKey">true</stringProp>
            <stringProp name="filename"></stringProp>
            <stringProp name="parameters"></stringProp>
            <stringProp name="scriptLanguage">groovy</stringProp>
            <stringProp name="script">
// Check the Location header for authFailure — indicates credentials were rejected
def headers = prev.getResponseHeaders()
if (headers != null &amp;&amp; headers.contains("authFailure=true")) {
    AssertionResult.setFailure(true)
    AssertionResult.setFailureMessage(
        "Authentication failed (authFailure=true in redirect).\n" +
        "Check testUsername/testPassword in config.properties."
    )
    return
}

def key = vars.get("postAuthSessionKey")
if (key == null || key == "POST_AUTH_KEY_NOT_FOUND") {
    AssertionResult.setFailure(true)
    AssertionResult.setFailureMessage(
        "Post-auth sessionDataKey not found in /commonauth redirect Location header.\n" +
        "Possible causes:\n" +
        "  1. Wrong credentials\n" +
        "  2. Adaptive script denied access or requires additional steps (TOTP, etc.)\n" +
        "  3. Unexpected IS response - check IS logs"
    )
}
            </stringProp>
          </JSR223Assertion>
          <hashTree/>
        </hashTree>

        <!-- STEP 2b: GET /t/carbon.super/oauth2/authorize?sessionDataKey=POST_AUTH_KEY
             IS 7.2.x internal re-authorization step that issues the auth code.
             This is an IS-internal redirect that always happens after /commonauth. -->
        <HTTPSamplerProxy guiclass="HttpTestSampleGui" testclass="HTTPSamplerProxy"
                          testname="2b GET /oauth2/authorize (Post-Auth)" enabled="true">
          <elementProp name="HTTPsampler.Arguments" elementType="Arguments"
                       guiclass="HTTPArgumentsPanel" testclass="Arguments" enabled="true">
            <collectionProp name="Arguments.arguments">
              <elementProp name="sessionDataKey" elementType="HTTPArgument">
                <boolProp name="HTTPArgument.always_encode">true</boolProp>
                <stringProp name="Argument.value">${postAuthSessionKey}</stringProp>
                <stringProp name="Argument.metadata">=</stringProp>
                <boolProp name="HTTPArgument.use_equals">true</boolProp>
                <stringProp name="Argument.name">sessionDataKey</stringProp>
              </elementProp>
            </collectionProp>
          </elementProp>
          <stringProp name="HTTPSampler.domain">${is_host}</stringProp>
          <stringProp name="HTTPSampler.port">${is_port}</stringProp>
          <stringProp name="HTTPSampler.protocol">https</stringProp>
          <stringProp name="HTTPSampler.path">/t/carbon.super/oauth2/authorize</stringProp>
          <stringProp name="HTTPSampler.method">GET</stringProp>
          <!-- Do NOT follow redirect: we want the auth code from Location header -->
          <boolProp name="HTTPSampler.follow_redirects">false</boolProp>
          <boolProp name="HTTPSampler.auto_redirects">false</boolProp>
          <boolProp name="HTTPSampler.use_keepalive">true</boolProp>
          <boolProp name="HTTPSampler.DO_MULTIPART_POST">false</boolProp>
          <stringProp name="HTTPSampler.implementation">HttpClient4</stringProp>
          <stringProp name="HTTPSampler.connect_timeout">10000</stringProp>
          <stringProp name="HTTPSampler.response_timeout">30000</stringProp>
          <stringProp name="TestPlan.comments">
            IS 7.2.x internal step: after /commonauth IS redirects here to issue the auth code.
            Expects HTTP 302 redirect to callbackUrl?code=AUTH_CODE
          </stringProp>
        </HTTPSamplerProxy>
        <hashTree>
          <!-- Assert 302 redirect to callback with code -->
          <ResponseAssertion guiclass="AssertionGui" testclass="ResponseAssertion"
                             testname="Assert 302 Redirect to Callback" enabled="true">
            <collectionProp name="Asserion.test_strings">
              <stringProp name="103171778">HTTP/1.1 302</stringProp>
            </collectionProp>
            <stringProp name="Assertion.test_field">Assertion.response_headers</stringProp>
            <boolProp name="Assertion.assume_success">false</boolProp>
            <intProp name="Assertion.test_type">2</intProp>
            <stringProp name="Assertion.custom_message">
              Step 2b failed: Expected 302 redirect from post-auth /oauth2/authorize.
              Check IS logs for authorization errors.
            </stringProp>
          </ResponseAssertion>
          <hashTree/>

          <!-- Extract auth code from the Location header (callbackUrl?code=AUTH_CODE) -->
          <RegexExtractor guiclass="RegexExtractorGui" testclass="RegexExtractor"
                          testname="Extract Auth Code" enabled="true">
            <stringProp name="RegexExtractor.useHeaders">true</stringProp>
            <stringProp name="RegexExtractor.refname">authCode</stringProp>
            <stringProp name="RegexExtractor.regex">code=([^&amp;\s"]+)</stringProp>
            <stringProp name="RegexExtractor.template">$1$</stringProp>
            <stringProp name="RegexExtractor.default">AUTH_CODE_NOT_FOUND</stringProp>
            <stringProp name="RegexExtractor.match_number">1</stringProp>
          </RegexExtractor>
          <hashTree/>

          <!-- Fail if auth code was not found -->
          <JSR223Assertion guiclass="TestBeanGUI" testclass="JSR223Assertion"
                           testname="Assert Auth Code Extracted" enabled="true">
            <stringProp name="cacheKey">true</stringProp>
            <stringProp name="filename"></stringProp>
            <stringProp name="parameters"></stringProp>
            <stringProp name="scriptLanguage">groovy</stringProp>
            <stringProp name="script">
def code = vars.get("authCode")
if (code == null || code == "AUTH_CODE_NOT_FOUND") {
    AssertionResult.setFailure(true)
    AssertionResult.setFailureMessage(
        "Auth code not found in redirect Location header after post-auth /oauth2/authorize.\n" +
        "Possible causes:\n" +
        "  1. Adaptive script requires an additional step (e.g. TOTP)\n" +
        "  2. Adaptive script denied access\n" +
        "  3. Consent page was shown - disable consent for the IS application"
    )
}
            </stringProp>
          </JSR223Assertion>
          <hashTree/>
        </hashTree>

        <!-- ADAPTIVE SCRIPT EXTENSION POINT:
             If your script adds extra steps (TOTP, SMS OTP, etc.),
             insert additional HTTP requests here between Step 2 and Step 3. -->

        <!-- STEP 3: POST /oauth2/token - Exchange auth code for tokens. -->
        <HTTPSamplerProxy guiclass="HttpTestSampleGui" testclass="HTTPSamplerProxy"
                          testname="3 POST /oauth2/token (Exchange Code)" enabled="true">
          <elementProp name="HTTPsampler.Arguments" elementType="Arguments"
                       guiclass="HTTPArgumentsPanel" testclass="Arguments" enabled="true">
            <collectionProp name="Arguments.arguments">
              <elementProp name="grant_type" elementType="HTTPArgument">
                <boolProp name="HTTPArgument.always_encode">false</boolProp>
                <stringProp name="Argument.value">authorization_code</stringProp>
                <stringProp name="Argument.metadata">=</stringProp>
                <boolProp name="HTTPArgument.use_equals">true</boolProp>
                <stringProp name="Argument.name">grant_type</stringProp>
              </elementProp>
              <elementProp name="code" elementType="HTTPArgument">
                <boolProp name="HTTPArgument.always_encode">true</boolProp>
                <stringProp name="Argument.value">${authCode}</stringProp>
                <stringProp name="Argument.metadata">=</stringProp>
                <boolProp name="HTTPArgument.use_equals">true</boolProp>
                <stringProp name="Argument.name">code</stringProp>
              </elementProp>
              <elementProp name="redirect_uri" elementType="HTTPArgument">
                <boolProp name="HTTPArgument.always_encode">true</boolProp>
                <stringProp name="Argument.value">${callbackUrl}</stringProp>
                <stringProp name="Argument.metadata">=</stringProp>
                <boolProp name="HTTPArgument.use_equals">true</boolProp>
                <stringProp name="Argument.name">redirect_uri</stringProp>
              </elementProp>
              <elementProp name="client_id" elementType="HTTPArgument">
                <boolProp name="HTTPArgument.always_encode">false</boolProp>
                <stringProp name="Argument.value">${clientId}</stringProp>
                <stringProp name="Argument.metadata">=</stringProp>
                <boolProp name="HTTPArgument.use_equals">true</boolProp>
                <stringProp name="Argument.name">client_id</stringProp>
              </elementProp>
              <elementProp name="client_secret" elementType="HTTPArgument">
                <boolProp name="HTTPArgument.always_encode">false</boolProp>
                <stringProp name="Argument.value">${clientSecret}</stringProp>
                <stringProp name="Argument.metadata">=</stringProp>
                <boolProp name="HTTPArgument.use_equals">true</boolProp>
                <stringProp name="Argument.name">client_secret</stringProp>
              </elementProp>
            </collectionProp>
          </elementProp>
          <stringProp name="HTTPSampler.domain">${is_host}</stringProp>
          <stringProp name="HTTPSampler.port">${is_port}</stringProp>
          <stringProp name="HTTPSampler.protocol">https</stringProp>
          <stringProp name="HTTPSampler.path">/oauth2/token</stringProp>
          <stringProp name="HTTPSampler.method">POST</stringProp>
          <boolProp name="HTTPSampler.follow_redirects">true</boolProp>
          <boolProp name="HTTPSampler.auto_redirects">false</boolProp>
          <boolProp name="HTTPSampler.use_keepalive">true</boolProp>
          <boolProp name="HTTPSampler.DO_MULTIPART_POST">false</boolProp>
          <stringProp name="HTTPSampler.implementation">HttpClient4</stringProp>
          <stringProp name="HTTPSampler.connect_timeout">10000</stringProp>
          <stringProp name="HTTPSampler.response_timeout">30000</stringProp>
        </HTTPSamplerProxy>
        <hashTree>
          <!-- Assert 200 OK -->
          <ResponseAssertion guiclass="AssertionGui" testclass="ResponseAssertion"
                             testname="Assert 200 Token Response" enabled="true">
            <collectionProp name="Asserion.test_strings">
              <stringProp name="103171775">HTTP/1.1 200</stringProp>
            </collectionProp>
            <stringProp name="Assertion.test_field">Assertion.response_headers</stringProp>
            <boolProp name="Assertion.assume_success">false</boolProp>
            <intProp name="Assertion.test_type">2</intProp>
            <stringProp name="Assertion.custom_message">
              Step 3 failed: /oauth2/token did not return 200.
              The auth code may be invalid or expired.
            </stringProp>
          </ResponseAssertion>
          <hashTree/>

          <!-- Assert access_token is present in response body -->
          <ResponseAssertion guiclass="AssertionGui" testclass="ResponseAssertion"
                             testname="Assert access_token Present" enabled="true">
            <collectionProp name="Asserion.test_strings">
              <stringProp name="417462488">&quot;access_token&quot;</stringProp>
            </collectionProp>
            <stringProp name="Assertion.test_field">Assertion.response_data</stringProp>
            <boolProp name="Assertion.assume_success">true</boolProp>
            <intProp name="Assertion.test_type">2</intProp>
            <stringProp name="Assertion.custom_message">
              access_token not found in token response body.
            </stringProp>
          </ResponseAssertion>
          <hashTree/>

          <!-- Assert id_token is present (OIDC) -->
          <ResponseAssertion guiclass="AssertionGui" testclass="ResponseAssertion"
                             testname="Assert id_token Present" enabled="true">
            <collectionProp name="Asserion.test_strings">
              <stringProp name="731531919">&quot;id_token&quot;</stringProp>
            </collectionProp>
            <stringProp name="Assertion.test_field">Assertion.response_data</stringProp>
            <boolProp name="Assertion.assume_success">true</boolProp>
            <intProp name="Assertion.test_type">2</intProp>
            <stringProp name="Assertion.custom_message">
              id_token not found in token response. Ensure scope includes openid.
            </stringProp>
          </ResponseAssertion>
          <hashTree/>
        </hashTree>

      </hashTree>

      <!-- =========================================================
           Results Collector - View Results Tree (enable in GUI mode)
           ========================================================= -->
      <ResultCollector guiclass="ViewResultsFullVisualizer" testclass="ResultCollector"
                       testname="View Results Tree" enabled="false">
        <boolProp name="ResultCollector.error_logging">false</boolProp>
        <objProp>
          <name>saveConfig</name>
          <value class="SampleSaveConfiguration">
            <time>true</time>
            <latency>true</latency>
            <timestamp>true</timestamp>
            <success>true</success>
            <label>true</label>
            <code>true</code>
            <message>true</message>
            <threadName>true</threadName>
            <dataType>true</dataType>
            <encoding>false</encoding>
            <assertions>true</assertions>
            <subresults>true</subresults>
            <responseData>true</responseData>
            <samplerData>false</samplerData>
            <xml>false</xml>
            <fieldNames>true</fieldNames>
            <responseHeaders>true</responseHeaders>
            <requestHeaders>true</requestHeaders>
            <responseDataOnError>true</responseDataOnError>
            <saveAssertionResultsFailureMessage>true</saveAssertionResultsFailureMessage>
            <bytes>true</bytes>
            <sentBytes>true</sentBytes>
            <threadCounts>true</threadCounts>
            <idleTime>true</idleTime>
            <connectTime>true</connectTime>
          </value>
        </objProp>
        <stringProp name="filename"></stringProp>
      </ResultCollector>
      <hashTree/>

    </hashTree>
  </hashTree>
</jmeterTestPlan>
