                <stringProp name="Argument.metadata">=</stringProp>
                <boolProp name="HTTPArgument.use_equals">true</boolProp>
                <stringProp name="Argument.name">response_type</stringProp>
              </elementProp>
              <elementProp name="scope" elementType="HTTPArgument">
                <boolProp name="HTTPArgument.always_encode">false</boolProp>
                <stringProp name="Argument.value">openid</stringProp>
                <stringProp name="Argument.metadata">=</stringProp>
                <boolProp name="HTTPArgument.use_equals">true</boolProp>
                <stringProp name="Argument.name">scope</stringProp>
              </elementProp>
            </collectionProp>
          </elementProp>
          <stringProp name="HTTPSampler.domain">${is_host}</stringProp>
          <stringProp name="HTTPSampler.port">${is_port}</stringProp>
          <stringProp name="HTTPSampler.protocol">https</stringProp>
          <stringProp name="HTTPSampler.path">/oauth2/authorize</stringProp>
          <stringProp name="HTTPSampler.method">GET</stringProp>
          <boolProp name="HTTPSampler.follow_redirects">false</boolProp>
          <boolProp name="HTTPSampler.auto_redirects">false</boolProp>
          <boolProp name="HTTPSampler.use_keepalive">true</boolProp>
          <boolProp name="HTTPSampler.DO_MULTIPART_POST">false</boolProp>
          <stringProp name="HTTPSampler.implementation">HttpClient4</stringProp>
          <stringProp name="HTTPSampler.connect_timeout">10000</stringProp>
          <stringProp name="HTTPSampler.response_timeout">30000</stringProp>
        </HTTPSamplerProxy>
        <hashTree>

          <!-- Load per-thread user from role_users.csv -->
          <JSR223PreProcessor guiclass="TestBeanGUI" testclass="JSR223PreProcessor"
                              testname="Load Per-Thread User from CSV" enabled="true">
            <stringProp name="cacheKey">false</stringProp>
            <stringProp name="filename"></stringProp>
            <stringProp name="parameters"></stringProp>
            <stringProp name="scriptLanguage">groovy</stringProp>
            <stringProp name="script">
import org.apache.jmeter.services.FileServer

def jmxDir = FileServer.getFileServer().getBaseDir()
def csvFile = new File(new File(jmxDir).getParent(), "testdata/role_users.csv")

if (!csvFile.exists()) {
    // Fallback to totp_users.csv for backward compatibility
    csvFile = new File(new File(jmxDir).getParent(), "testdata/totp_users.csv")
    if (!csvFile.exists()) {
        log.error("No CSV found. Run setup/setup_role_users.sh first.")
        return
    }
}

def dataLines = csvFile.readLines().drop(1)  // skip header
int threadIdx = ctx.getThreadNum() % dataLines.size()
def parts = dataLines[threadIdx].split(",", -1)  // -1 to keep empty trailing fields

vars.put("testUsername", parts[0].trim())
vars.put("testPassword", parts[1].trim())
vars.put("totpSecret",   parts.length > 2 ? parts[2].trim() : "")
vars.put("userRole",     parts.length > 3 ? parts[3].trim() : "unknown")

// Reset flow control variables
vars.put("needsTOTP", "false")

log.debug("Thread " + (ctx.getThreadNum() + 1) + " -> " + parts[0].trim() + " (role=" + vars.get("userRole") + ")")
            </stringProp>
          </JSR223PreProcessor>
          <hashTree/>

          <!-- Assert 302 -->
          <ResponseAssertion guiclass="AssertionGui" testclass="ResponseAssertion"
                             testname="Assert 302 Redirect to Login" enabled="true">
            <collectionProp name="Asserion.test_strings">
              <stringProp name="103171778">HTTP/1.1 302</stringProp>
            </collectionProp>
            <stringProp name="Assertion.test_field">Assertion.response_headers</stringProp>
            <boolProp name="Assertion.assume_success">false</boolProp>
            <intProp name="Assertion.test_type">2</intProp>
            <stringProp name="Assertion.custom_message">
              Step 1 failed: Expected 302 redirect from /oauth2/authorize.
            </stringProp>
          </ResponseAssertion>
          <hashTree/>

          <!-- Extract sessionDataKey -->
          <RegexExtractor guiclass="RegexExtractorGui" testclass="RegexExtractor"
                          testname="Extract sessionDataKey" enabled="true">
            <stringProp name="RegexExtractor.useHeaders">true</stringProp>
            <stringProp name="RegexExtractor.refname">sessionDataKey</stringProp>
            <stringProp name="RegexExtractor.regex">sessionDataKey=([^&amp;\s"]+)</stringProp>
            <stringProp name="RegexExtractor.template">$1$</stringProp>
            <stringProp name="RegexExtractor.default">SESSION_DATA_KEY_NOT_FOUND</stringProp>
            <stringProp name="RegexExtractor.match_number">1</stringProp>
          </RegexExtractor>
          <hashTree/>

          <JSR223Assertion guiclass="TestBeanGUI" testclass="JSR223Assertion"
                           testname="Assert sessionDataKey Extracted" enabled="true">
            <stringProp name="cacheKey">true</stringProp>
            <stringProp name="filename"></stringProp>
            <stringProp name="parameters"></stringProp>
            <stringProp name="scriptLanguage">groovy</stringProp>
            <stringProp name="script">
def key = vars.get("sessionDataKey")
if (key == null || key == "SESSION_DATA_KEY_NOT_FOUND") {
    AssertionResult.setFailure(true)
    AssertionResult.setFailureMessage("sessionDataKey not found. Check clientId and IS config.")
}
            </stringProp>
          </JSR223Assertion>
          <hashTree/>
        </hashTree>

        <!-- ============================================================ -->
        <!-- STEP 2: POST /commonauth (Submit Password)                   -->
        <!-- After this, IS either redirects to TOTP page (admin/manager) -->
        <!-- or to oauth2/authorize (employee). We detect which path.     -->
        <!-- ============================================================ -->
        <HTTPSamplerProxy guiclass="HttpTestSampleGui" testclass="HTTPSamplerProxy"
                          testname="2 POST /commonauth (Submit Password)" enabled="true">
          <elementProp name="HTTPsampler.Arguments" elementType="Arguments"
                       guiclass="HTTPArgumentsPanel" testclass="Arguments" enabled="true">
            <collectionProp name="Arguments.arguments">
              <elementProp name="sessionDataKey" elementType="HTTPArgument">
                <boolProp name="HTTPArgument.always_encode">true</boolProp>
                <stringProp name="Argument.value">${sessionDataKey}</stringProp>
                <stringProp name="Argument.metadata">=</stringProp>
                <boolProp name="HTTPArgument.use_equals">true</boolProp>
                <stringProp name="Argument.name">sessionDataKey</stringProp>
              </elementProp>
              <elementProp name="username" elementType="HTTPArgument">
                <boolProp name="HTTPArgument.always_encode">true</boolProp>
                <stringProp name="Argument.value">${testUsername}</stringProp>
                <stringProp name="Argument.metadata">=</stringProp>
                <boolProp name="HTTPArgument.use_equals">true</boolProp>
                <stringProp name="Argument.name">username</stringProp>
              </elementProp>
              <elementProp name="password" elementType="HTTPArgument">
                <boolProp name="HTTPArgument.always_encode">true</boolProp>
                <stringProp name="Argument.value">${testPassword}</stringProp>
                <stringProp name="Argument.metadata">=</stringProp>
                <boolProp name="HTTPArgument.use_equals">true</boolProp>
                <stringProp name="Argument.name">password</stringProp>
              </elementProp>
            </collectionProp>
          </elementProp>
          <stringProp name="HTTPSampler.domain">${is_host}</stringProp>
          <stringProp name="HTTPSampler.port">${is_port}</stringProp>
          <stringProp name="HTTPSampler.protocol">https</stringProp>
          <stringProp name="HTTPSampler.path">/commonauth</stringProp>
          <stringProp name="HTTPSampler.method">POST</stringProp>
          <boolProp name="HTTPSampler.follow_redirects">false</boolProp>
          <boolProp name="HTTPSampler.auto_redirects">false</boolProp>
          <boolProp name="HTTPSampler.use_keepalive">true</boolProp>
          <boolProp name="HTTPSampler.DO_MULTIPART_POST">false</boolProp>
          <stringProp name="HTTPSampler.implementation">HttpClient4</stringProp>
          <stringProp name="HTTPSampler.connect_timeout">10000</stringProp>
          <stringProp name="HTTPSampler.response_timeout">30000</stringProp>
        </HTTPSamplerProxy>
        <hashTree>
          <!-- Assert 302 -->
          <ResponseAssertion guiclass="AssertionGui" testclass="ResponseAssertion"
                             testname="Assert 302 After Password" enabled="true">
            <collectionProp name="Asserion.test_strings">
              <stringProp name="103171778">HTTP/1.1 302</stringProp>
            </collectionProp>
            <stringProp name="Assertion.test_field">Assertion.response_headers</stringProp>
            <boolProp name="Assertion.assume_success">false</boolProp>
            <intProp name="Assertion.test_type">2</intProp>
            <stringProp name="Assertion.custom_message">
              Step 2 failed: Expected 302 after password submission.
            </stringProp>
          </ResponseAssertion>
          <hashTree/>

          <!-- Detect which path: TOTP or direct auth code -->
          <JSR223PostProcessor guiclass="TestBeanGUI" testclass="JSR223PostProcessor"
                                testname="Detect TOTP or Direct Auth" enabled="true">
            <stringProp name="cacheKey">true</stringProp>
            <stringProp name="filename"></stringProp>
            <stringProp name="parameters"></stringProp>
            <stringProp name="scriptLanguage">groovy</stringProp>
            <stringProp name="script">
def headers = prev.getResponseHeaders()
if (headers == null) {
    vars.put("needsTOTP", "false")
    return
}

// Check for auth failure
if (headers.contains("authFailure=true")) {
    vars.put("needsTOTP", "false")
    vars.put("authFailed", "true")
    return
}

// Extract Location header
def locationMatch = (headers =~ /Location:\s*(.+)/)
if (!locationMatch.find()) {
    vars.put("needsTOTP", "false")
    return
}
def location = locationMatch.group(1).trim()

if (location.contains("totp.do") || location.contains("totp")) {
    // Admin/Manager path: TOTP step needed
    vars.put("needsTOTP", "true")
    // Extract TOTP sessionDataKey
    def keyMatch = (location =~ /sessionDataKey=([^&amp;\s"]+)/)
    if (keyMatch.find()) {
        vars.put("totpSessionKey", keyMatch.group(1))
    }
    log.debug("TOTP step needed for " + vars.get("testUsername"))
} else if (location.contains("oauth2/authorize")) {
    // Employee path: no TOTP, extract postAuthSessionKey directly
    vars.put("needsTOTP", "false")
    def keyMatch = (location =~ /sessionDataKey=([^&amp;\s"]+)/)
    if (keyMatch.find()) {
        vars.put("postAuthSessionKey", keyMatch.group(1))
    }
    log.debug("No TOTP for " + vars.get("testUsername") + " (direct to authorize)")
} else {
    vars.put("needsTOTP", "false")
}
            </stringProp>
          </JSR223PostProcessor>
          <hashTree/>

          <!-- Assert no auth failure -->
          <JSR223Assertion guiclass="TestBeanGUI" testclass="JSR223Assertion"
                           testname="Assert Password Accepted" enabled="true">
            <stringProp name="cacheKey">true</stringProp>
            <stringProp name="filename"></stringProp>
            <stringProp name="parameters"></stringProp>
            <stringProp name="scriptLanguage">groovy</stringProp>
            <stringProp name="script">
if ("true".equals(vars.get("authFailed"))) {
    AssertionResult.setFailure(true)
    AssertionResult.setFailureMessage(
        "Password authentication failed (authFailure=true).\n" +
        "User: " + vars.get("testUsername") + " Role: " + vars.get("userRole")
    )
}
// Reset for next iteration
vars.put("authFailed", "false")
            </stringProp>
          </JSR223Assertion>
          <hashTree/>
        </hashTree>

        <!-- ============================================================ -->
        <!-- STEP 2c: POST /commonauth (Submit TOTP Code)                 -->
        <!-- Only executes for admin/manager users (needsTOTP=true)        -->
        <!-- ============================================================ -->
        <IfController guiclass="IfControllerPanel" testclass="IfController"
                      testname="If TOTP Needed" enabled="true">
          <stringProp name="IfController.condition">${__groovy(vars.get("needsTOTP") == "true")}</stringProp>
          <boolProp name="IfController.evaluateAll">false</boolProp>
          <boolProp name="IfController.useExpression">true</boolProp>
        </IfController>
        <hashTree>
          <HTTPSamplerProxy guiclass="HttpTestSampleGui" testclass="HTTPSamplerProxy"
                            testname="2c POST /commonauth (Submit TOTP Code)" enabled="true">
            <elementProp name="HTTPsampler.Arguments" elementType="Arguments"
                         guiclass="HTTPArgumentsPanel" testclass="Arguments" enabled="true">
              <collectionProp name="Arguments.arguments">
                <elementProp name="sessionDataKey" elementType="HTTPArgument">
                  <boolProp name="HTTPArgument.always_encode">true</boolProp>
                  <stringProp name="Argument.value">${totpSessionKey}</stringProp>
                  <stringProp name="Argument.metadata">=</stringProp>
                  <boolProp name="HTTPArgument.use_equals">true</boolProp>
                  <stringProp name="Argument.name">sessionDataKey</stringProp>
                </elementProp>
                <elementProp name="token" elementType="HTTPArgument">
                  <boolProp name="HTTPArgument.always_encode">false</boolProp>
                  <stringProp name="Argument.value">${totpCode}</stringProp>
                  <stringProp name="Argument.metadata">=</stringProp>
                  <boolProp name="HTTPArgument.use_equals">true</boolProp>
                  <stringProp name="Argument.name">token</stringProp>
                </elementProp>
              </collectionProp>
            </elementProp>
            <stringProp name="HTTPSampler.domain">${is_host}</stringProp>
            <stringProp name="HTTPSampler.port">${is_port}</stringProp>
            <stringProp name="HTTPSampler.protocol">https</stringProp>
            <stringProp name="HTTPSampler.path">/commonauth</stringProp>
            <stringProp name="HTTPSampler.method">POST</stringProp>
            <boolProp name="HTTPSampler.follow_redirects">false</boolProp>
            <boolProp name="HTTPSampler.auto_redirects">false</boolProp>
            <boolProp name="HTTPSampler.use_keepalive">true</boolProp>
            <boolProp name="HTTPSampler.DO_MULTIPART_POST">false</boolProp>
            <stringProp name="HTTPSampler.implementation">HttpClient4</stringProp>
            <stringProp name="HTTPSampler.connect_timeout">10000</stringProp>
            <stringProp name="HTTPSampler.response_timeout">30000</stringProp>
          </HTTPSamplerProxy>
          <hashTree>

            <!-- Calculate TOTP code -->
            <JSR223PreProcessor guiclass="TestBeanGUI" testclass="JSR223PreProcessor"
                                testname="Calculate TOTP Code" enabled="true">
              <stringProp name="cacheKey">true</stringProp>
              <stringProp name="filename"></stringProp>
              <stringProp name="parameters"></stringProp>
              <stringProp name="scriptLanguage">groovy</stringProp>
              <stringProp name="script">
import javax.crypto.Mac
import javax.crypto.spec.SecretKeySpec
import java.nio.ByteBuffer

def base32Decode(String encoded) {
    def alphabet = "ABCDEFGHIJKLMNOPQRSTUVWXYZ234567"
    encoded = encoded.toUpperCase().replaceAll("[= \\-]", "")
    def bits = new StringBuilder()
    encoded.each { c ->
        int idx = alphabet.indexOf((int) c.charAt(0))
        if (idx >= 0) {
            bits.append(String.format("%5s", Integer.toBinaryString(idx)).replace(' ', '0'))
        }
    }
    def byteList = []
    for (int i = 0; i + 8 &lt;= bits.length(); i += 8) {
        byteList &lt;&lt; ((int) Integer.parseInt(bits.substring(i, i + 8), 2)).byteValue()
    }
    return byteList as byte[]
}

def secret = vars.get("totpSecret")
if (secret == null || secret.trim().isEmpty()) {
    log.error("totpSecret is empty for user " + vars.get("testUsername") + " but TOTP step was triggered")
    vars.put("totpCode", "000000")
    return
}

// TOTP Replay Protection
long nowMs = System.currentTimeMillis()
long currentTimeStep = nowMs / 1000L / 30L

String lastStepKey = "lastTotpTimeStep"
String lastStepStr = vars.get(lastStepKey)
if (lastStepStr != null) {
    long lastStep = Long.parseLong(lastStepStr)
    if (currentTimeStep == lastStep) {
        long nextWindowMs = (currentTimeStep + 1) * 30L * 1000L
        long sleepMs = nextWindowMs - nowMs + 100
        if (sleepMs > 0) {
            log.info("TOTP replay guard: sleeping " + sleepMs + "ms until next 30s window")
            Thread.sleep(sleepMs)
        }
        currentTimeStep = System.currentTimeMillis() / 1000L / 30L
    }
}
vars.put(lastStepKey, String.valueOf(currentTimeStep))

// Compute TOTP (RFC 6238 / HMAC-SHA1)
byte[] key = base32Decode(secret.trim())
byte[] msg = ByteBuffer.allocate(8).putLong(currentTimeStep).array()

Mac mac = Mac.getInstance("HmacSHA1")
mac.init(new SecretKeySpec(key, "HmacSHA1"))
byte[] hash = mac.doFinal(msg)

int offset = hash[hash.length - 1] &amp; 0x0f
int b0 = hash[offset]     &amp; 0x7f
int b1 = hash[offset + 1] &amp; 0xff
int b2 = hash[offset + 2] &amp; 0xff
int b3 = hash[offset + 3] &amp; 0xff
int otp = (b0 * 16777216) + (b1 * 65536) + (b2 * 256) + b3
otp = otp % 1000000

vars.put("totpCode", String.format("%06d", otp))
              </stringProp>
            </JSR223PreProcessor>
            <hashTree/>

            <!-- Assert 302 -->
            <ResponseAssertion guiclass="AssertionGui" testclass="ResponseAssertion"
                               testname="Assert 302 from TOTP" enabled="true">
              <collectionProp name="Asserion.test_strings">
                <stringProp name="103171778">HTTP/1.1 302</stringProp>
              </collectionProp>
              <stringProp name="Assertion.test_field">Assertion.response_headers</stringProp>
              <boolProp name="Assertion.assume_success">false</boolProp>
              <intProp name="Assertion.test_type">2</intProp>
              <stringProp name="Assertion.custom_message">
                Step 2c failed: Expected 302 after TOTP submission.
              </stringProp>
            </ResponseAssertion>
            <hashTree/>

            <!-- Extract postAuthSessionKey -->
            <RegexExtractor guiclass="RegexExtractorGui" testclass="RegexExtractor"
                            testname="Extract Post-Auth SessionDataKey" enabled="true">
              <stringProp name="RegexExtractor.useHeaders">true</stringProp>
              <stringProp name="RegexExtractor.refname">postAuthSessionKey</stringProp>
              <stringProp name="RegexExtractor.regex">sessionDataKey=([^&amp;\s"]+)</stringProp>
              <stringProp name="RegexExtractor.template">$1$</stringProp>
              <stringProp name="RegexExtractor.default">POST_AUTH_KEY_NOT_FOUND</stringProp>
              <stringProp name="RegexExtractor.match_number">1</stringProp>
            </RegexExtractor>
            <hashTree/>

            <!-- Assert TOTP accepted -->
            <JSR223Assertion guiclass="TestBeanGUI" testclass="JSR223Assertion"
                             testname="Assert TOTP Accepted" enabled="true">
              <stringProp name="cacheKey">true</stringProp>
              <stringProp name="filename"></stringProp>
              <stringProp name="parameters"></stringProp>
              <stringProp name="scriptLanguage">groovy</stringProp>
              <stringProp name="script">
def headers = prev.getResponseHeaders()
if (headers != null &amp;&amp; headers.contains("authFailure=true")) {
    AssertionResult.setFailure(true)
    AssertionResult.setFailureMessage(
        "TOTP code rejected (authFailure=true). User: " + vars.get("testUsername")
    )
    return
}
def key = vars.get("postAuthSessionKey")
if (key == null || key == "POST_AUTH_KEY_NOT_FOUND") {
    AssertionResult.setFailure(true)
    AssertionResult.setFailureMessage(
        "postAuthSessionKey not found after TOTP. User: " + vars.get("testUsername")
    )
}
              </stringProp>
            </JSR223Assertion>
            <hashTree/>
          </hashTree>
        </hashTree>

        <!-- ============================================================ -->
        <!-- STEP 2b: GET /t/carbon.super/oauth2/authorize (Post-Auth)    -->
        <!-- Runs for ALL users — extracts auth code from redirect         -->
        <!-- ============================================================ -->
        <HTTPSamplerProxy guiclass="HttpTestSampleGui" testclass="HTTPSamplerProxy"
                          testname="2b GET /oauth2/authorize (Post-Auth)" enabled="true">
          <elementProp name="HTTPsampler.Arguments" elementType="Arguments"
                       guiclass="HTTPArgumentsPanel" testclass="Arguments" enabled="true">
            <collectionProp name="Arguments.arguments">
              <elementProp name="sessionDataKey" elementType="HTTPArgument">
                <boolProp name="HTTPArgument.always_encode">true</boolProp>
                <stringProp name="Argument.value">${postAuthSessionKey}</stringProp>
                <stringProp name="Argument.metadata">=</stringProp>
                <boolProp name="HTTPArgument.use_equals">true</boolProp>
                <stringProp name="Argument.name">sessionDataKey</stringProp>
              </elementProp>
            </collectionProp>
          </elementProp>
          <stringProp name="HTTPSampler.domain">${is_host}</stringProp>
          <stringProp name="HTTPSampler.port">${is_port}</stringProp>
          <stringProp name="HTTPSampler.protocol">https</stringProp>
          <stringProp name="HTTPSampler.path">/t/carbon.super/oauth2/authorize</stringProp>
          <stringProp name="HTTPSampler.method">GET</stringProp>
          <boolProp name="HTTPSampler.follow_redirects">false</boolProp>
          <boolProp name="HTTPSampler.auto_redirects">false</boolProp>
          <boolProp name="HTTPSampler.use_keepalive">true</boolProp>
          <boolProp name="HTTPSampler.DO_MULTIPART_POST">false</boolProp>
          <stringProp name="HTTPSampler.implementation">HttpClient4</stringProp>
          <stringProp name="HTTPSampler.connect_timeout">10000</stringProp>
          <stringProp name="HTTPSampler.response_timeout">30000</stringProp>
        </HTTPSamplerProxy>
        <hashTree>
          <ResponseAssertion guiclass="AssertionGui" testclass="ResponseAssertion"
                             testname="Assert 302 Redirect to Callback" enabled="true">
            <collectionProp name="Asserion.test_strings">
              <stringProp name="103171778">HTTP/1.1 302</stringProp>
            </collectionProp>
            <stringProp name="Assertion.test_field">Assertion.response_headers</stringProp>
            <boolProp name="Assertion.assume_success">false</boolProp>
            <intProp name="Assertion.test_type">2</intProp>
            <stringProp name="Assertion.custom_message">
              Step 2b failed: Expected 302 redirect to callback.
            </stringProp>
          </ResponseAssertion>
          <hashTree/>

          <RegexExtractor guiclass="RegexExtractorGui" testclass="RegexExtractor"
                          testname="Extract Auth Code" enabled="true">
            <stringProp name="RegexExtractor.useHeaders">true</stringProp>
            <stringProp name="RegexExtractor.refname">authCode</stringProp>
            <stringProp name="RegexExtractor.regex">code=([^&amp;\s"]+)</stringProp>
            <stringProp name="RegexExtractor.template">$1$</stringProp>
            <stringProp name="RegexExtractor.default">AUTH_CODE_NOT_FOUND</stringProp>
            <stringProp name="RegexExtractor.match_number">1</stringProp>
          </RegexExtractor>
          <hashTree/>

          <JSR223Assertion guiclass="TestBeanGUI" testclass="JSR223Assertion"
                           testname="Assert Auth Code Extracted" enabled="true">
            <stringProp name="cacheKey">true</stringProp>
            <stringProp name="filename"></stringProp>
            <stringProp name="parameters"></stringProp>
            <stringProp name="scriptLanguage">groovy</stringProp>
            <stringProp name="script">
def code = vars.get("authCode")
if (code == null || code == "AUTH_CODE_NOT_FOUND") {
    AssertionResult.setFailure(true)
    AssertionResult.setFailureMessage(
        "Auth code not found. User: " + vars.get("testUsername") +
        " Role: " + vars.get("userRole") +
        " TOTP path: " + vars.get("needsTOTP")
    )
}
            </stringProp>
          </JSR223Assertion>
          <hashTree/>
        </hashTree>

        <!-- ============================================================ -->
        <!-- STEP 3: POST /oauth2/token (Exchange Code)                   -->
        <!-- ============================================================ -->
        <HTTPSamplerProxy guiclass="HttpTestSampleGui" testclass="HTTPSamplerProxy"
                          testname="3 POST /oauth2/token (Exchange Code)" enabled="true">
          <elementProp name="HTTPsampler.Arguments" elementType="Arguments"
                       guiclass="HTTPArgumentsPanel" testclass="Arguments" enabled="true">
            <collectionProp name="Arguments.arguments">
              <elementProp name="grant_type" elementType="HTTPArgument">
                <boolProp name="HTTPArgument.always_encode">false</boolProp>
                <stringProp name="Argument.value">authorization_code</stringProp>
                <stringProp name="Argument.metadata">=</stringProp>
                <boolProp name="HTTPArgument.use_equals">true</boolProp>
                <stringProp name="Argument.name">grant_type</stringProp>
              </elementProp>
              <elementProp name="code" elementType="HTTPArgument">
                <boolProp name="HTTPArgument.always_encode">true</boolProp>
                <stringProp name="Argument.value">${authCode}</stringProp>
                <stringProp name="Argument.metadata">=</stringProp>
                <boolProp name="HTTPArgument.use_equals">true</boolProp>
                <stringProp name="Argument.name">code</stringProp>
              </elementProp>
              <elementProp name="redirect_uri" elementType="HTTPArgument">
                <boolProp name="HTTPArgument.always_encode">true</boolProp>
                <stringProp name="Argument.value">${callbackUrl}</stringProp>
                <stringProp name="Argument.metadata">=</stringProp>
                <boolProp name="HTTPArgument.use_equals">true</boolProp>
                <stringProp name="Argument.name">redirect_uri</stringProp>
              </elementProp>
              <elementProp name="client_id" elementType="HTTPArgument">
                <boolProp name="HTTPArgument.always_encode">false</boolProp>
                <stringProp name="Argument.value">${clientId}</stringProp>
                <stringProp name="Argument.metadata">=</stringProp>
                <boolProp name="HTTPArgument.use_equals">true</boolProp>
                <stringProp name="Argument.name">client_id</stringProp>
              </elementProp>
              <elementProp name="client_secret" elementType="HTTPArgument">
                <boolProp name="HTTPArgument.always_encode">false</boolProp>
                <stringProp name="Argument.value">${clientSecret}</stringProp>
                <stringProp name="Argument.metadata">=</stringProp>
                <boolProp name="HTTPArgument.use_equals">true</boolProp>
                <stringProp name="Argument.name">client_secret</stringProp>
              </elementProp>
            </collectionProp>
          </elementProp>
          <stringProp name="HTTPSampler.domain">${is_host}</stringProp>
          <stringProp name="HTTPSampler.port">${is_port}</stringProp>
          <stringProp name="HTTPSampler.protocol">https</stringProp>
          <stringProp name="HTTPSampler.path">/oauth2/token</stringProp>
          <stringProp name="HTTPSampler.method">POST</stringProp>
          <boolProp name="HTTPSampler.follow_redirects">true</boolProp>
          <boolProp name="HTTPSampler.auto_redirects">false</boolProp>
          <boolProp name="HTTPSampler.use_keepalive">true</boolProp>
          <boolProp name="HTTPSampler.DO_MULTIPART_POST">false</boolProp>
          <stringProp name="HTTPSampler.implementation">HttpClient4</stringProp>
          <stringProp name="HTTPSampler.connect_timeout">10000</stringProp>
          <stringProp name="HTTPSampler.response_timeout">30000</stringProp>
        </HTTPSamplerProxy>
        <hashTree>
          <ResponseAssertion guiclass="AssertionGui" testclass="ResponseAssertion"
                             testname="Assert 200 Token Response" enabled="true">
            <collectionProp name="Asserion.test_strings">
              <stringProp name="103171775">HTTP/1.1 200</stringProp>
            </collectionProp>
            <stringProp name="Assertion.test_field">Assertion.response_headers</stringProp>
            <boolProp name="Assertion.assume_success">false</boolProp>
            <intProp name="Assertion.test_type">2</intProp>
            <stringProp name="Assertion.custom_message">
              Step 3 failed: /oauth2/token did not return 200.
            </stringProp>
          </ResponseAssertion>
          <hashTree/>

          <ResponseAssertion guiclass="AssertionGui" testclass="ResponseAssertion"
                             testname="Assert access_token Present" enabled="true">
            <collectionProp name="Asserion.test_strings">
              <stringProp name="417462488">&quot;access_token&quot;</stringProp>
            </collectionProp>
            <stringProp name="Assertion.test_field">Assertion.response_data</stringProp>
            <boolProp name="Assertion.assume_success">true</boolProp>
            <intProp name="Assertion.test_type">2</intProp>
            <stringProp name="Assertion.custom_message">
              access_token not found in token response.
            </stringProp>
          </ResponseAssertion>
          <hashTree/>

          <ResponseAssertion guiclass="AssertionGui" testclass="ResponseAssertion"
                             testname="Assert id_token Present" enabled="true">
            <collectionProp name="Asserion.test_strings">
              <stringProp name="731531919">&quot;id_token&quot;</stringProp>
            </collectionProp>
            <stringProp name="Assertion.test_field">Assertion.response_data</stringProp>
            <boolProp name="Assertion.assume_success">true</boolProp>
            <intProp name="Assertion.test_type">2</intProp>
            <stringProp name="Assertion.custom_message">
              id_token not found in token response.
            </stringProp>
          </ResponseAssertion>
          <hashTree/>
        </hashTree>

      </hashTree>

      <!-- View Results Tree (disabled, enable in GUI for debugging) -->
      <ResultCollector guiclass="ViewResultsFullVisualizer" testclass="ResultCollector"
                       testname="View Results Tree" enabled="false">
        <boolProp name="ResultCollector.error_logging">false</boolProp>
        <objProp>
          <name>saveConfig</name>
          <value class="SampleSaveConfiguration">
            <time>true</time>
            <latency>true</latency>
            <timestamp>true</timestamp>
            <success>true</success>
            <label>true</label>
            <code>true</code>
            <message>true</message>
            <threadName>true</threadName>
            <dataType>true</dataType>
            <encoding>false</encoding>
            <assertions>true</assertions>
            <subresults>true</subresults>
            <responseData>true</responseData>
            <samplerData>false</samplerData>
            <xml>false</xml>
            <fieldNames>true</fieldNames>
            <responseHeaders>true</responseHeaders>
            <requestHeaders>true</requestHeaders>
            <responseDataOnError>true</responseDataOnError>
            <saveAssertionResultsFailureMessage>true</saveAssertionResultsFailureMessage>
            <bytes>true</bytes>
            <sentBytes>true</sentBytes>
            <threadCounts>true</threadCounts>
            <idleTime>true</idleTime>
            <connectTime>true</connectTime>
          </value>
        </objProp>
        <stringProp name="filename"></stringProp>
      </ResultCollector>
      <hashTree/>

    </hashTree>
  </hashTree>
</jmeterTestPlan>
