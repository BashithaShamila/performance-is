<?xml version="1.0" encoding="UTF-8"?>
<jmeterTestPlan version="1.2" properties="5.0" jmeter="5.5">
  <hashTree>
    <TestPlan guiclass="TestPlanGui" testclass="TestPlan"
              testname="Adaptive Scripting - Role-Based Conditional TOTP Flow" enabled="true">
      <stringProp name="TestPlan.comments">
        Tests OIDC Authorization Code flow where the adaptive script uses
        hasAnyOfTheRolesV2 to conditionally add TOTP as step 2.

        Adaptive script under test:
          var rolesToStepUp = ['admin', 'manager'];
          var onLoginRequest = function(context) {
              executeStep(1, {
                  onSuccess: function(context) {
                      var user = context.currentKnownSubject;
                      if (user &amp;&amp; hasAnyOfTheRolesV2(context, rolesToStepUp)) {
                          executeStep(2, { ... });
                      }
                  }
              });
          };

        Flow depends on user role:
          admin/manager:  authorize -> password -> TOTP -> auth code -> token
          employee:       authorize -> password -> auth code -> token

        Users are loaded from testdata/role_users.csv (generated by setup_role_users.sh).
        Each row has: username,password,totpSecret,role
        - admin/manager rows have a totpSecret (enrolled in TOTP)
        - employee rows have an empty totpSecret (no TOTP)

        The JMX detects which path to take by checking the redirect Location
        after the password step:
          - Contains "totp.do" -> TOTP step needed (admin/manager)
          - Contains "oauth2/authorize" -> skip TOTP (employee)
      </stringProp>
      <boolProp name="TestPlan.functional_mode">false</boolProp>
      <boolProp name="TestPlan.serialize_threadgroups">false</boolProp>
      <elementProp name="TestPlan.user_defined_variables" elementType="Arguments"
                   guiclass="ArgumentsPanel" testclass="Arguments" enabled="true">
        <collectionProp name="Arguments.arguments"/>
      </elementProp>
      <stringProp name="TestPlan.user_define_classpath"></stringProp>
    </TestPlan>
    <hashTree>

