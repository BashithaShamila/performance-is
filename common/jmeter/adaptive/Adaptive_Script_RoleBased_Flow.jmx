          <stringProp name="parameters"></stringProp>
          <boolProp name="resetInterpreter">false</boolProp>
          <stringProp name="script">String deploymentType = vars.get("deployment");
int numOfNodes = Integer.parseInt(vars.get("noOfNodes"));
int x = ctx.getThreadNum() + 1;
int y = x - (x/numOfNodes)*numOfNodes;

if (y == 0 || "active-passive".equals(deploymentType)) {
    vars.put("serverNode", "node1");
} else if (y == 1) {
    vars.put("serverNode", "node2");
} else if (y == 2) {
    vars.put("serverNode", "node3");
} else {
    vars.put("serverNode", "node4");
}</stringProp>
        </BeanShellPreProcessor>
