      <hashTree>

        <!-- Load credentials and CSV once per thread at start -->
        <JSR223PreProcessor guiclass="TestBeanGUI" testclass="JSR223PreProcessor"
                            testname="Load Credentials and Per-Thread User from CSV" enabled="true">
          <stringProp name="cacheKey">false</stringProp>
          <stringProp name="filename"></stringProp>
          <stringProp name="parameters"></stringProp>
          <stringProp name="scriptLanguage">groovy</stringProp>
          <stringProp name="script">
import org.apache.jmeter.services.FileServer

// --- Load app credentials (once per thread) ---
if (vars.get("clientId") == null || vars.get("clientId") == "NOT_LOADED") {
    // Try cloud path first, then local path
    def credsFile = new File("/home/ubuntu/adaptive_app_creds.csv")
    if (!credsFile.exists()) {
        def jmxDir = FileServer.getFileServer().getBaseDir()
        credsFile = new File(new File(jmxDir).getParent(), "adaptive_app_creds.csv")
    }
    if (credsFile.exists()) {
        def credsLines = credsFile.readLines().drop(1) // skip header
        if (credsLines.size() &gt; 0) {
            def creds = credsLines[0].split(",", -1)
            vars.put("clientId", creds[0].trim())
            vars.put("clientSecret", creds[1].trim())
            vars.put("callbackUrl", creds.length &gt; 2 ? creds[2].trim() : "https://localhost/callback")
            log.info("Loaded app creds: clientId=" + creds[0].trim())
        }
    } else {
        // Fallback: use JMeter properties (for local testing)
        vars.put("clientId", props.get("clientId") ?: "YOUR_CLIENT_ID_HERE")
        vars.put("clientSecret", props.get("clientSecret") ?: "YOUR_CLIENT_SECRET_HERE")
        vars.put("callbackUrl", props.get("callbackUrl") ?: "https://localhost/callback")
        log.warn("No creds file found, using JMeter properties")
    }
}

// --- Load per-thread user from CSV ---
// Try cloud path first, then local path
def csvFile = new File("/home/ubuntu/testdata/role_users.csv")
if (!csvFile.exists()) {
    def jmxDir = FileServer.getFileServer().getBaseDir()
    csvFile = new File(new File(jmxDir).getParent(), "testdata/role_users.csv")
    if (!csvFile.exists()) {
        csvFile = new File(new File(jmxDir).getParent(), "testdata/totp_users.csv")
    }
}
if (!csvFile.exists()) {
    log.error("No CSV found at /home/ubuntu/testdata/ or local testdata/")
    return
}

def allLines = csvFile.readLines().drop(1)  // skip header
// Filter to employee users only (managers/admins require TOTP which isn't enrolled)
def dataLines = allLines.findAll { line -&gt;
    def cols = line.split(",", -1)
    cols.length &lt; 4 || cols[3].trim() == "employee" || cols[3].trim() == ""
}
if (dataLines.isEmpty()) dataLines = allLines  // fallback to all if no employees found
int threadIdx = ctx.getThreadNum() % dataLines.size()
def parts = dataLines[threadIdx].split(",", -1)

vars.put("testUsername", parts[0].trim())
vars.put("testPassword", parts[1].trim())
vars.put("totpSecret",   parts.length &gt; 2 ? parts[2].trim() : "")
vars.put("userRole",     parts.length &gt; 3 ? parts[3].trim() : "unknown")

// Reset flow control variables
vars.put("needsTOTP", "false")

log.debug("Thread " + (ctx.getThreadNum() + 1) + " -&gt; " + parts[0].trim() + " (role=" + vars.get("userRole") + ")")
          </stringProp>
        </JSR223PreProcessor>
        <hashTree/>

